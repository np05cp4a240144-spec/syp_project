generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  MECHANIC
}

model User {
  id                  Int           @id @default(autoincrement())
  email               String        @unique
  name                String?
  password            String
  role                Role          @default(USER)
  phone               String?
  speciality          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  vehicles            Vehicle[]
  appointments        Appointment[] @relation("CustomerAppointments")
  mechanicAssignments Appointment[] @relation("MechanicAssignments")
  sentMessages        Message[]     @relation("SentMessages")
  receivedMessages    Message[]     @relation("ReceivedMessages")
  ratings             Rating[]
}

model Vehicle {
  id           Int           @id @default(autoincrement())
  make         String
  model        String
  year         Int
  plate        String        @unique
  color        String?
  mileage      Int?
  ownerId      Int
  owner        User          @relation(fields: [ownerId], references: [id])
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id         Int         @id @default(autoincrement())
  service    String
  status     String      @default("Pending")
  stage      String      @default("Pending")
  progress   Int         @default(0)
  time       String
  amount     Float?
  isPaid     Boolean     @default(false)
  userId     Int
  user       User        @relation("CustomerAppointments", fields: [userId], references: [id])
  vehicleId  Int
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id])
  mechanicId Int?
  mechanic   User?       @relation("MechanicAssignments", fields: [mechanicId], references: [id])
  messages   Message[]
  parts      JobPart[]
  updates    JobUpdate[]
  invoice    Invoice?
  rating     Rating?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Invoice {
  id            Int         @id @default(autoincrement())
  invoiceNumber String      @unique
  laborCost     Float       @default(0.0)
  partsTotal    Float       @default(0.0)
  tax           Float       @default(0.0)
  totalAmount   Float       @default(0.0)
  notes         String?     @db.Text
  appointmentId Int         @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Message {
  id            Int          @id @default(autoincrement())
  content       String       @db.Text
  senderId      Int
  sender        User         @relation("SentMessages", fields: [senderId], references: [id])
  receiverId    Int
  receiver      User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  appointmentId Int?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  read          Boolean      @default(false)
  createdAt     DateTime     @default(now())
}

model Part {
  id        Int       @id @default(autoincrement())
  name      String
  sku       String    @unique
  category  String
  price     Float     @default(0.0)
  stock     Int       @default(0)
  minStock  Int       @default(5)
  maxStock  Int       @default(50)
  unit      String    @default("units")
  status    String    @default("OK")
  logs      PartLog[]
  jobParts  JobPart[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PartLog {
  id        Int      @id @default(autoincrement())
  type      String // "Stock In", "Stock Out", "Manual Adjustment"
  amount    Int
  notes     String?
  partId    Int
  part      Part     @relation(fields: [partId], references: [id])
  userId    Int?
  createdAt DateTime @default(now())
}

model JobPart {
  id            Int         @id @default(autoincrement())
  quantity      Int         @default(1)
  priceAtTime   Float?      @default(0.0)
  appointmentId Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  partId        Int
  part          Part        @relation(fields: [partId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model JobUpdate {
  id            Int         @id @default(autoincrement())
  content       String      @db.Text
  appointmentId Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime    @default(now())
}

model Rating {
  id            Int          @id @default(autoincrement())
  ratingType    String // "MECHANIC" or "SYSTEM" (legacy ADMIN supported in API)
  score         Int // 1-5
  comment       String?      @db.Text
  customerId    Int
  customer      User         @relation(fields: [customerId], references: [id])
  appointmentId Int?         @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  serviceName   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([customerId])
  @@index([serviceName])
}

model PendingPartPayment {
  id             Int      @id @default(autoincrement())
  pidx           String   @unique
  userId         Int
  expectedAmount Int
  items          Json
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}
